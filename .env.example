# ============================================================
# MemFlow 环境变量配置模板
# 复制此文件为 .env 并填写真实值
# cp .env.example .env
# ============================================================

# ─── LLM API Keys ─────────────────────────────────────────
# 至少配置一个 LLM Provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# 其他可选 Provider
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# OpenAI 兼容 API（如 LocalAI, Ollama）
OPENAI_BASE_URL=

# ─── MemFlow 核心认证 ──────────────────────────────────────
# 管理员 API Key（运行 install 脚本时自动生成）
EXECUTOR_API_KEY=your-admin-key-here
# 兼容旧版字段名
MEMFLOW_API_KEY=${EXECUTOR_API_KEY}

# ─── 网络 & 端口 ───────────────────────────────────────────
# Executor 监听端口
PORT=8080
HOST=0.0.0.0
# Agent 端口（如启用 agent 服务）
AGENT_PORT=3000
# 前端端口（Nginx）
FRONTEND_PORT=80
# 前端开发服务器端口
VITE_DEV_PORT=5173
# 前端 API URL（构建时注入，默认通过 /api 代理到 agent-service）
VITE_API_URL=/api
# 兼容旧字段名
VITE_API_BASE_URL=${VITE_API_URL}

# ─── 数据库 ────────────────────────────────────────────────
# SQLite（本地/Binary 模式）
DATABASE_PATH=./data/memflow.db
# PostgreSQL（Docker/云端模式，取消注释以启用）
# DATABASE_URL=postgres://postgres:changeme@postgres:5432/memflow
DATABASE_URL=postgres://postgres:changeme@localhost:5432/memflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=memflow
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# 带密码: redis://:password@redis:6379
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_MAX_MEM=256mb

# ─── ClickHouse（可选，用于大规模日志分析）────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=memflow
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# ─── MemFlow 功能配置 ──────────────────────────────────────
MEMFLOW_API_URL=http://executor:8080
LOG_LEVEL=info
RUST_LOG=info
MAX_CONCURRENT_WORKFLOWS=20
AUTO_LEARNING_ENABLED=true
AUTONOMY_ENABLED=true
AUTONOMY_INTERVAL_SECONDS=120
AUTONOMY_OBJECTIVE=Continuously improve workflow reliability with safe autonomous tuning and evidence logging.
# 工作流版本保留数量
MAX_VERSIONS_PER_WORKFLOW=10
# 执行日志保留天数
LOG_RETENTION_DAYS=30
# 时区
TZ=Asia/Shanghai

# ─── 限流 & 安全 ───────────────────────────────────────────
# 每分钟最大 API 请求数（0 = 不限制）
RATE_LIMIT_GLOBAL=0
# CORS 允许来源（逗号分隔，* 表示全部）
CORS_ORIGINS=*
# HTTPS（仅 binary 模式且有 TLS 证书时启用）
# SSL_CERT_PATH=/etc/ssl/certs/memflow.crt
# SSL_KEY_PATH=/etc/ssl/private/memflow.key

# ─── Docker 部署配置 ───────────────────────────────────────
DOCKER_SUBNET=172.20.0.0/16
# 资源限制（Docker Swarm / Compose deploy）
EXECUTOR_CPU_LIMIT=2
EXECUTOR_MEM_LIMIT=2G
AGENT_CPU_LIMIT=1
AGENT_MEM_LIMIT=1G

# ─── 云平台部署专项配置 ────────────────────────────────────
# 数据目录（本地 binary 模式）
DATA_DIR=~/memflow-data

# --- Zeabur ---
# 直接使用 Zeabur 控制台注入环境变量即可，无需额外配置

# --- Railway ---
# Railway 自动注入 PORT，此处留空由平台覆盖
# PORT=          # Railway 自动设置

# --- Render ---
# Render 使用 DATABASE_URL (PostgreSQL) 和 REDIS_URL (Redis)
# 在 Render Dashboard > Environment 中配置

# --- Fly.io ---
# fly secrets set EXECUTOR_API_KEY=xxx
# fly secrets set ANTHROPIC_API_KEY=xxx

# --- AWS Elastic Beanstalk / ECS ---
# 在 .ebextensions 或 ECS Task Definition 中注入环境变量
# 推荐使用 AWS Secrets Manager 存储敏感 Key

# --- GCP Cloud Run ---
# gcloud run deploy --set-env-vars EXECUTOR_API_KEY=xxx
# 推荐使用 Google Secret Manager 存储敏感 Key

# --- Azure Container Apps ---
# az containerapp update --set-env-vars EXECUTOR_API_KEY=xxx

# --- DigitalOcean App Platform ---
# 在 App Spec 的 envs 字段中配置

# --- Aliyun ACK / Tencent TKE ---
# 使用 ConfigMap + Secret 注入环境变量

# ─── 可观测性（可选）──────────────────────────────────────
# Sentry 错误追踪
# SENTRY_DSN=https://xxx@sentry.io/xxx
# Datadog APM
# DD_API_KEY=
# DD_SITE=datadoghq.com
# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── 备份（可选）──────────────────────────────────────────
# S3 兼容对象存储（AWS S3, MinIO, Aliyun OSS, Tencent COS 等）
# S3_BUCKET=memflow-backups
# S3_REGION=ap-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=             # 非 AWS S3 时填写端点
