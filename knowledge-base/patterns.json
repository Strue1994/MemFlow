    },
    {
      "id": "ai-agent-workflow",
      "name": "AI Agent Workflow Pattern",
      "description": "Build AI agents with tool access, memory, and reasoning capabilities",
      "use_cases": ["Chatbot with tool access", "AI assistant with database access", "Automated decision making system"],
      "structure": "Trigger → AI Agent (Model + Tools + Memory) → Output",
      "key_components": [
        { "name": "Trigger", "options": ["Webhook", "Manual", "Schedule"] },
        { "name": "AI Agent", "config": { "agent": "conversationalAgent | openAIFunctionsAgent" } },
        { "name": "Language Model", "providers": ["OpenAI", "Anthropic", "Google", "Ollama"] },
        { "name": "Tools", "description": "Any n8n node can be a tool via ai_tool port" },
        { "name": "Memory", "types": ["Buffer Memory", "Window Buffer Memory", "Summary Memory"] }
      ]
    },
    {
      "id": "database-operations",
      "name": "Database Operations Pattern",
      "description": "Database query, insert, update, and transaction patterns",
      "use_cases": ["Data synchronization between services", "CRM data manipulation", "Reporting and analytics pipelines"],
      "key_components": ["Database node (PostgreSQL, MySQL, MongoDB)", "Transform node", "Error handling"]
    },
    {
      "id": "http-api-integration",
      "name": "HTTP API Integration Pattern",
      "description": "Call external APIs with authentication, pagination, error handling",
      "use_cases": ["Third-party service integration", "REST API data fetching", "OAuth authenticated requests"],
      "key_considerations": ["Authentication (API Key, OAuth, Bearer)", "Pagination", "Rate limiting", "Response transformation"]
    },
    {
      "id": "orchestration-patterns",
      "name": "Orchestration Patterns",
      "description": "Complex workflow orchestration with parallel execution, loops, and error handling",
      "use_cases": ["Multi-step data processing", "Parallel task execution", "Conditional branching"],
      "patterns": ["Sequential execution", "Parallel execution (split into batches)", "Loop over items (for each)", "Switch/If conditions"]
    }
  ]
}